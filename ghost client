local function findMyCollectZone()
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil, "Нет персонажа", 0 end

    local myPos  = hrp.Position
    local results = getAllZones()

    if #results == 0 then
        return nil, "Зон не найдено", 0
    end

    -- Убираем дубликаты (ближе 10 студс)
    local unique = {}
    for _, r in ipairs(results) do
        local isDup = false
        for _, u in ipairs(unique) do
            if (r.pos - u.pos).Magnitude < 10 then
                isDup = true
                break
            end
        end
        if not isDup then
            table.insert(unique, r)
        end
    end

    -- Сортируем — БЛИЖАЙШАЯ зона = своя зона сбора
    table.sort(unique, function(a, b)
        return (a.pos - myPos).Magnitude < (b.pos - myPos).Magnitude
    end)

    -- Берём ближайшую
    local best = unique[1]

    -- Если уже стоим прямо на ней — берём следующую
    if (best.pos - myPos).Magnitude < 8 and #unique > 1 then
        best = unique[2]
    end

    stealZonePos  = best.pos
    foundZoneName = best.name
    return best.pos, best.name, #unique
end

