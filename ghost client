-- ========== HITBOX ВІЗУАЛІЗАЦІЯ ==========
local hitboxParts = {}
local highlight = Instance.new("Highlight")
highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
highlight.FillColor = Color3.fromRGB(255, 0, 0)
highlight.FillTransparency = 0.7
highlight.OutlineTransparency = 0.3
highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

local function updateHitboxView()
    if not _G.HitboxView then
        for _, part in pairs(hitboxParts) do
            if part and part.Parent then
                part:Destroy()
            end
        end
        hitboxParts = {}
        if highlight.Parent then highlight.Parent = nil end
        return
    end
    
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character.Parent then
            local char = otherPlayer.Character
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                -- Створюємо візуальний хітбокс
                local box = Instance.new("BoxHandleAdornment")
                box.Size = Vector3.new(3.5 * hitboxScale, 5 * hitboxScale, 1.8 * hitboxScale)
                box.Adornee = root
                box.Color3 = Color3.fromRGB(255, 0, 0)
                box.Transparency = 0.5
                box.ZIndex = 0
                box.AlwaysOnTop = _G.SeeThroughWalls or false
                box.Parent = root
                table.insert(hitboxParts, box)
            end
        end
    end
end

-- Оновлення через кожен кадр
RunService.RenderStepped:Connect(function()
    updateHitboxView()
end)

-- Оновлення Wallhack
local function updateWallhack()
    if _G.Wallhack then
        for _, otherPlayer in pairs(Players:GetPlayers()) do
            if otherPlayer ~= player and otherPlayer.Character then
                local highlightClone = highlight:Clone()
                highlightClone.Parent = otherPlayer.Character
            end
        end
    else
        for _, otherPlayer in pairs(Players:GetPlayers()) do
            if otherPlayer ~= player and otherPlayer.Character then
                for _, h in pairs(otherPlayer.Character:GetChildren()) do
                    if h:IsA("Highlight") then h:Destroy() end
                end
            end
        end
    end
end

-- При появі нового гравця
Players.PlayerAdded:Connect(function(newPlayer)
