-- Функція створення/оновлення хітбокса для персонажа
local function applyHitboxToCharacter(character)
    if not character or character == player.Character then return end
    
    -- Шукаємо або створюємо хітбокс
    local hitbox = character:FindFirstChild("GhostHitbox")
    
    if not hitbox then
        hitbox = Instance.new("BoxHandleAdornment")
        hitbox.Name = "GhostHitbox"
        hitbox.Adornee = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Head")
        hitbox.AlwaysOnTop = true
        hitbox.ZIndex = 10
        hitbox.Transparency = 0.7
        hitbox.Color3 = Color3.fromRGB(255, 0, 0)
        hitbox.Visible = true
        hitbox.Parent = character
    end
    
    -- Оновлюємо розмір
    if hitbox then
        hitbox.Size = Vector3.new(hitboxMultiplier, hitboxMultiplier, hitboxMultiplier)
        -- Оновлюємо колір залежно від розміру
        local colorValue = math.clamp((hitboxMultiplier - 1) / 9, 0, 1)
        hitbox.Color3 = Color3.fromRGB(
            255,
            math.floor(255 * (1 - colorValue)),
            0
        )
    end
    
    -- Зберігаємо зв'язок для відстеження
    if not hitboxConnections[character] then
        hitboxConnections[character] = true
    end
end

-- Функція застосування розміру до всіх хітбоксів
local function setAllHitboxSizes()
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= player.Character then
            applyHitboxToCharacter(v)
        end
    end
end

