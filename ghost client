-- safe_auto_gui.lua
-- LocalScript (поместите в StarterPlayerScripts)
-- Цель: автоматически показать адаптивный центрированный GUI с прогресс-баром (1%->100% за 7.5s)
-- Ключевые требования выполнены:
--  - Нет game:HttpGet, loadstring, syn.request, http_request и т.п.
--  - Все WaitForChild с таймаутом; pcall вокруг критичных операций
--  - GUI создаётся автоматически при старте, центрируется и масштабируется под экран
--  - Прогресс 1% -> 100% за 7.5s (1% каждые 0.075s)
--  - Плавный fade-out по завершении
--  - Отладочные сообщения

local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local GuiService = game:GetService("GuiService")

print("[DEBUG] Скрипт запущен (auto GUI)")

-- Безопасное получение LocalPlayer (первая строка безопасна)
local player = Players.LocalPlayer
if not player then
    local ok, lp = pcall(function()
        return Players:WaitForChild("LocalPlayer", 2)
    end)
    if ok and lp then
        player = lp
    else
        warn("[ERROR] LocalPlayer не найден. Скрипт завершает работу.")
        return
    end
end

-- Безопасная функция WaitForChild с таймаутом
local function safeWait(parent, name, timeout)
    if not parent then return nil end
    timeout = timeout or 2
    local ok, result = pcall(function()
        return parent:WaitForChild(name, timeout)
    end)
    if ok then
        return result
    else
        return nil
    end
end

-- Попытка получить PlayerGui с fallback (требование: ждать до 5 секунд, затем CoreGui/StarterGui)
local function getGuiContainer(plr)
    -- Попробуем PlayerGui с таймаутом 5s
    local pg = safeWait(plr, "PlayerGui", 5)
    if pg then
        return pg, "PlayerGui"
    end

    -- Попытка CoreGui (в pcall, т.к. доступ может быть ограничен)
    local ok, cg = pcall(function() return CoreGui end)
    if ok and cg then
        return cg, "CoreGui"
    end

    -- Фоллбек на StarterGui
    return StarterGui, "StarterGui"
end

local guiContainer, containerName = getGuiContainer(player)
print(("[DEBUG] GUI контейнер выбран: %s"):format(tostring(containerName)))

-- Функция создания адаптивного GUI (в pcall)
local function createAdaptiveGui(parent)
    if not parent then
        return nil, "parent is nil"
    end

    local success, result = pcall(function()
        -- Создаём ScreenGui
        local screenGui = Instance.new("ScreenGui")
        screenGui.Name = "GHOST_CLIENT_GUI"
        screenGui.ResetOnSpawn = false
        screenGui.Enabled = true
        -- Попытка установить IgnoreGuiInset безопасно
        pcall(function() screenGui.IgnoreGuiInset = true end)

        -- Основной контейнер (центрированный)
        local mainFrame = Instance.new("Frame")
        mainFrame.Name = "MainFrame"
        -- Центрируем: AnchorPoint 0.5,0.5 и Position 0.5,0.5
        mainFrame.AnchorPoint = Vector2.new(0.5, 0.5)
        mainFrame.Position = UDim2.fromScale(0.5, 0.5)
        -- Размеры относительные: ширина 0.6 экрана, высота фиксированная 260px (будет масштабироваться через UIScale)
        mainFrame.Size = UDim2.new(0.6, 0, 0, 260)
        mainFrame.BackgroundColor3 = Color3.fromHex("0f0f1a")
        mainFrame.BackgroundTransparency = 0.08
        mainFrame.BorderSizePixel = 0
        mainFrame.Parent = screenGui

        -- Скругления
        local corner = Instance.new("UICorner")
        corner.CornerRadius = UDim.new(0, 12)
        corner.Parent = mainFrame

        -- Внешняя подсветка (UIStroke) — декоративно
        local stroke = Instance.new("UIStroke")
        stroke.Color = Color3.fromHex("00ccff")
        stroke.Transparency = 0.88
        stroke.Thickness = 1
        stroke.Parent = mainFrame

        -- UIScale для адаптации под разные экраны (мобильные/ПК)
        local uiScale = Instance.new("UIScale")
        uiScale.Name = "AutoUIScale"
        uiScale.Parent = mainFrame
        -- Инициализация масштаба (будет обновляться ниже)
        uiScale.Scale = 1

        -- Заголовок (GHO👻T CLIENT) — иконка призрака вместо 'S'
        local title = Instance.new("TextLabel")
        title.Name = "Title"
        title.Size = UDim2.new(1, -40, 0, 64)
        title.Position = UDim2.new(0, 20, 0, 18)
        title.BackgroundTransparency = 1
        title.Text = "GHO" .. "👻" .. "T CLIENT"
        title.Font = Enum.Font.GothamBold
        title.TextSize = 36
        title.TextColor3 = Color3.new(1,1,1)
        title.TextXAlignment = Enum.TextXAlignment.Left
        title.Parent = mainFrame

        -- Подзаголовок
        local subtitle = Instance.new("TextLabel")
        subtitle.Name = "Subtitle"
        subtitle.Size = UDim2.new(1, -40, 0, 22)
        subtitle.Position = UDim2.new(0, 20, 0, 86)
        subtitle.BackgroundTransparency = 1
        subtitle.Text = "CLIENT"
        subtitle.Font = Enum.Font.GothamSemibold
        subtitle.TextSize = 14
        subtitle.TextColor3 = Color3.new(1,1,1)
        subtitle.TextXAlignment = Enum.TextXAlignment.Left
        subtitle.Parent = mainFrame

        -- Прогресс-бар: контейнер и заполнение
        local progressBg = Instance.new("Frame")
        progressBg.Name = "ProgressBg"
        -- Относительная ширина внутри mainFrame: 0.7 (70% ширины mainFrame)
        progressBg.Size = UDim2.new(0.7, 0, 0, 14)
        progressBg.Position = UDim2.new(0.5, 0, 1, -56) -- снизу mainFrame
        progressBg.AnchorPoint = Vector2.new(0.5, 1)
        progressBg.BackgroundColor3 = Color3.fromHex("22222e")
        progressBg.BorderSizePixel = 0
        progressBg.Parent = mainFrame
        local bgCorner = Instance.new("UICorner")
        bgCorner.CornerRadius = UDim.new(0, 12)
        bgCorner.Parent = progressBg

        local progressFill = Instance.new("Frame")
        progressFill.Name = "ProgressFill"
        progressFill.Size = UDim2.new(0, 0, 1, 0) -- начальное 0%
        progressFill.Position = UDim2.new(0, 0, 0, 0)
        progressFill.BackgroundColor3 = Color3.fromHex("00ccff")
        progressFill.BorderSizePixel = 0
        progressFill.Parent = progressBg
        local fillCorner = Instance.new("UICorner")
        fillCorner.CornerRadius = UDim.new(0, 12)
        fillCorner.Parent = progressFill

        -- Иконка призрака слева от полосы (20x20)
        local ghostIcon = Instance.new("TextLabel")
        ghostIcon.Name = "GhostIcon"
        ghostIcon.Size = UDim2.new(0, 20, 0, 20)
        ghostIcon.Position = UDim2.new(0.5, -(progressBg.Size.X.Offset/2) - 36, 1, -56) -- слева от полосы
        ghostIcon.AnchorPoint = Vector2.new(0.5, 1)
        ghostIcon.BackgroundTransparency = 1
        ghostIcon.Text = "👻"
        ghostIcon.Font = Enum.Font.SourceSansBold
        ghostIcon.TextSize = 18
        ghostIcon.TextColor3 = Color3.new(1,1,1)
        ghostIcon.Parent = mainFrame

        -- Проценты справа от полосы
        local percentLabel = Instance.new("TextLabel")
        percentLabel.Name = "Percent"
        percentLabel.Size = UDim2.new(0, 48, 0, 20)
        percentLabel.Position = UDim2.new(0.5, (progressBg.Size.X.Offset/2) + 36, 1, -56)
        percentLabel.AnchorPoint = Vector2.new(0.5, 1)
        percentLabel.BackgroundTransparency = 1
        percentLabel.Text = "0%"
        percentLabel.Font = Enum.Font.GothamBold
        percentLabel.TextSize = 14
        percentLabel.TextColor3 = Color3.new(1,1,1)
        percentLabel.Parent = mainFrame

        -- Стилизация текста: лёгкое свечение (через UIStroke с прозрачностью)
        local titleStroke = Instance.new("UIStroke")
        titleStroke.Color = Color3.fromHex("00ccff")
        titleStroke.Transparency = 0.9
        titleStroke.Thickness = 0.8
        titleStroke.Parent = title

        -- Скрываем GUI по умолчанию? Требование: показывать автоматически — поэтому оставляем Enabled = true
        screenGui.Enabled = true

        -- Родительство
        screenGui.Parent = parent

        -- Возвращаем созданный GUI
        return screenGui
    end)

    if not success then
        return nil, tostring(result)
    end

    return result
end

-- Создаём GUI
local createdGui, createErr = createAdaptiveGui(guiContainer)
if not createdGui then
    warn("[ERROR] Не удалось создать GUI: " .. tostring(createErr))
    return
end
print("[DEBUG] GUI успешно создан и добавлен в контейнер")

-- Функция обновления масштаба UIScale в зависимости от экрана (адаптация под мобильные/ПК)
local function updateScale()
    if not createdGui then return end
    local main = createdGui:FindFirstChild("MainFrame")
    if not main then return end
    local uiScale = main:FindFirstChild("AutoUIScale")
    if not uiScale then return end

    -- Получаем разрешение экрана
    local screenX, screenY = workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.X or 1280, workspace.CurrentCamera and workspace.CurrentCamera.ViewportSize.Y or 720
    -- Базовый дизайн ориентирован на 1920x1080
    local scaleX = screenX / 1920
    local scaleY = screenY / 1080
    local baseScale = math.min(scaleX, scaleY)
    -- Ограничиваем масштаб, чтобы UI не стал слишком маленьким или большим
    local finalScale = math.clamp(baseScale, 0.65, 1.15)

    -- Дополнительно увеличиваем для мобильных устройств (TouchEnabled)
    if UserInputService.TouchEnabled then
        finalScale = finalScale * 1.05
    end

    -- Применяем плавно через Tween
    pcall(function()
        TweenService:Create(uiScale, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Scale = finalScale}):Play()
    end)
end

-- Подписываемся на изменение размера экрана
local resizeConn
local function connectResize()
    -- Отписываем старое, если есть
    if resizeConn then
        resizeConn:Disconnect()
        resizeConn = nil
    end
    -- Используем RenderStepped/Heartbeat для плавного обновления при изменении размера
    resizeConn = RunService.Heartbeat:Connect(function()
        updateScale()
    end)
end
connectResize()
-- Первичная установка масштаба
updateScale()

-- Функция анимации прогресс-бара (1% -> 100% за 7.5s)
local function runProgress(gui)
    if not gui then return end
    local main = gui:FindFirstChild("MainFrame")
    if not main then
        warn("[ERROR] MainFrame не найден в GUI")
        return
    end
    local progressBg = main:FindFirstChild("ProgressBg")
    local progressFill = progressBg and progressBg:FindFirstChild("ProgressFill")
    local percentLabel = main:FindFirstChild("Percent")
    if not progressFill or not percentLabel then
        warn("[ERROR] Элементы прогресс-бара не найдены")
        return
    end

    -- Анимация: 1% каждые 75ms
    local percent = 0
    local stepMs = 75
    local accumulated = 0
    local running = true
    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not running then
            if conn then conn:Disconnect() end
            return
        end
        accumulated = accumulated + dt * 1000
        while accumulated >= stepMs and percent < 100 do
            accumulated = accumulated - stepMs
            percent = percent + 1
            -- Обновляем UI в pcall
            pcall(function()
                -- Размер заполнения: относительная ширина (процент)
                progressFill.Size = UDim2.new(percent / 100, 0, 1, 0)
                percentLabel.Text = tostring(percent) .. "%"
            end)
        end

        if percent >= 100 then
            running = false
            if conn then conn:Disconnect() end

            -- Плавный fade-out: уменьшаем прозрачность mainFrame и текста
            pcall(function()
                local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
                local goals = {BackgroundTransparency = 1}
                local t = TweenService:Create(main, tweenInfo, goals)
                t:Play()
                -- Текстовые элементы
                local title = main:FindFirstChild("Title")
                local subtitle = main:FindFirstChild("Subtitle")
                local percentLbl = main:FindFirstChild("Percent")
                if title then TweenService:Create(title, tweenInfo, {TextTransparency = 1}):Play() end
                if subtitle then TweenService:Create(subtitle, tweenInfo, {TextTransparency = 1}):Play() end
                if percentLbl then TweenService:Create(percentLbl, tweenInfo, {TextTransparency = 1}):Play() end
                -- Запускаем ещё один таймер, чтобы полностью отключить GUI после анимации
                delay(0.55, function()
                    pcall(function()
                        -- Отключаем GUI (без удаления)
                        gui.Enabled = false
                    end)
                    print("[DEBUG] Загрузка завершена, GUI скрыт")
                end)
            end)
        end
    end)
end

-- Запускаем прогресс автоматически при создании GUI
pcall(function()
    runProgress(createdGui)
end)

print("[DEBUG] Автоматический показ GUI и запуск прогресса выполнены")

-- Дополнительно: реагируем на изменение ориентации/режима (например, мобильная ориентация)
-- Обновляем масштаб при изменении ввода (например, подключение/отключение сенсорного ввода)
UserInputService.TouchEnabledChanged:Connect(function()
    updateScale()
end)

-- Обработка изменения размера окна (вдобавок к Heartbeat)
if workspace.CurrentCamera then
    workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
        updateScale()
    end)
end

