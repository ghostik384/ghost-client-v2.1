-- LocalScript: safe_console_gui.lua
-- Место: StarterPlayerScripts или StarterGui (LocalScript)
-- Автор: исправленный скрипт для безопасного создания GUI при вводе /console

--[[
  Что было исправлено (комментарии внутри кода также отмечают места исправлений):
  - Убраны все опасные вызовы в первой строке (game:HttpGet, loadstring, syn.request и т.д.).
  - Первая строка теперь безопасна: получаем LocalPlayer через GetService и проверяем.
  - Все WaitForChild имеют таймауты; критичные участки обёрнуты в pcall.
  - Добавлен fallback: CoreGui (в pcall) или StarterGui, если PlayerGui не доступен.
  - Добавлены debug/warn сообщения.
  - Обработчик чата защищён от ошибок.
--]]

-- Безопасное получение LocalPlayer (первая строка безопасна)
local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local CoreGui = game:GetService("CoreGui")
local RunService = game:GetService("RunService")

print("[DEBUG] Скрипт запущен")

-- Проверяем LocalPlayer; если нет — завершаем (LocalScript должен выполняться на клиенте)
local player = Players.LocalPlayer
if not player then
    -- В некоторых окружениях LocalPlayer может быть nil на очень ранней стадии.
    -- Попробуем дождаться его появления в течение короткого времени.
    local ok, lp = pcall(function()
        return Players:WaitForChild("LocalPlayer", 2)
    end)
    if ok and lp then
        player = lp
    else
        warn("[ERROR] LocalPlayer не найден. Скрипт завершает работу.")
        return
    end
end

-- Функция безопасного ожидания дочернего объекта с таймаутом и проверкой
local function safeWait(parent, childName, timeout)
    if not parent then return nil end
    timeout = timeout or 2
    local ok, result = pcall(function()
        return parent:WaitForChild(childName, timeout)
    end)
    if ok then
        return result
    else
        return nil
    end
end

-- Попытка получить PlayerGui с таймаутом 5 секунд (требование)
local function getPlayerGuiWithFallback(player)
    -- Сначала пробуем стандартный путь
    local playerGui = safeWait(player, "PlayerGui", 5)
    if playerGui then
        return playerGui, "PlayerGui"
    end

    -- Если PlayerGui не появился — пробуем CoreGui (в pcall, т.к. в обычной среде доступ может быть запрещён)
    local ok, cg = pcall(function()
        -- В обычной Roblox LocalScript не может родительствовать в CoreGui,
        -- но в некоторых окружениях/эксплойтах это возможно — пробуем.
        return CoreGui
    end)
    if ok and cg then
        return cg, "CoreGui"
    end

    -- В крайнем случае используем StarterGui как запасной контейнер (не всегда отображается, но безопасно)
    return StarterGui, "StarterGui"
end

-- Функция создания GUI (всё в pcall)
