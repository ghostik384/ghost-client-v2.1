-- Функція оновлення слайдера
local function updateSlider(value)
    local percent = (value - 1) / 1.5 -- 1 -> 0, 2.5 -> 1
    percent = math.clamp(percent, 0, 1)
    
    sliderFill.Size = UDim2.new(percent, 0, 1, 0)
    sliderKnob.Position = UDim2.new(percent, -10, 0.5, -10)
    hitboxLabel.Text = "Hitbox Size: " .. string.format("%.1f", value) .. "x"
    hitboxMultiplier = value
    
    -- Застосовуємо розмір до хітбоксів
    setAllHitboxes()
end

-- Глобальний стан перетягування
local sliderDragging = false

-- Функція розрахунку позиції з координат вводу
local function getSliderPercent(inputX)
    local bgPos = sliderBackground.AbsolutePosition.X
    local bgSize = sliderBackground.AbsoluteSize.X
    local percent = (inputX - bgPos) / bgSize
    return math.clamp(percent, 0, 1)
end

-- Функція застосування процента до значення слайдера
local function applySliderPercent(percent)
    local value = 1 + (percent * 1.5)
    updateSlider(value)
end

-- === ОБРОБНИКИ ПОДІЙ ДЛЯ СЛАЙДЕРА ===

-- Клік на фон слайдера
sliderBackground.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        sliderDragging = true
        local percent = getSliderPercent(input.Position.X)
        applySliderPercent(percent)
    end
end)

-- Клік на ручку слайдера
sliderKnob.InputBegan:Connect(function(input)
