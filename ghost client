<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>GHOST CLIENT</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
<style>
 * { box-sizing: border-box; margin: 0; padding: 0; }
 html, body {
   height: 100%;
   font-family: 'Montserrat', 'Roboto', sans-serif;
   background:
     radial-gradient(ellipse at top, #1a1a2e 0%, #0f0f1a 60%, #06060c 100%);
   color: #e8e8f5;
   overflow: hidden;
   user-select: none;
   -webkit-user-select: none;
 }

 /* Floating ghost icon (when GUI closed) */
 .ghost-toggle {
   position: fixed;
   top: 15px;
   left: 15px;
   width: 55px;
   height: 55px;
   border-radius: 50%;
   background: rgba(30, 30, 47, 0.9);
   border: 1px solid #3a3a5a;
   display: flex;
   align-items: center;
   justify-content: center;
   cursor: pointer;
   z-index: 9999;
   backdrop-filter: blur(8px);
   font-size: 28px;
   line-height: 1;
   opacity: 1;
   transform: scale(1);
   transition: background 0.2s ease, box-shadow 0.2s ease,
               transform 0.28s cubic-bezier(.2,.9,.3,1.2),
               opacity 0.28s ease;
 }
 .ghost-toggle:hover {
   background: rgba(58, 58, 90, 0.95);
   box-shadow: 0 0 18px rgba(140, 100, 255, 0.55);
   transform: scale(1.08);
 }
 .ghost-toggle:active { transform: scale(0.94); }
 .ghost-toggle.hidden {
   opacity: 0;
   transform: scale(0.5) rotate(-12deg);
   pointer-events: none;
 }

 /* GUI window */
 .gui {
   position: fixed;
   top: 50%;
   left: 50%;
   translate: -50% -50%;
   scale: 1;
   width: 650px;
   height: 450px;
   max-width: calc(100vw - 24px);
   max-height: calc(100vh - 24px);
   background: #0d0d15;
   border: 1px solid #3a3a5a;
   border-radius: 12px;
   box-shadow:
     0 20px 60px rgba(0, 0, 0, 0.6),
     0 0 30px rgba(90, 60, 180, 0.15);
   display: flex;
   flex-direction: column;
   overflow: hidden;
   opacity: 1;
   transform-origin: center;
   transition: opacity 0.3s ease,
               scale 0.32s cubic-bezier(.2,.9,.3,1.2),
               filter 0.3s ease;
 }
 .gui.dragged { translate: 0 0; }
 .gui.hidden {
   opacity: 0;
   scale: 0.9;
   filter: blur(4px);
   pointer-events: none;
 }

 /* Top bar */
 .gui-top {
   height: 44px;
   background: linear-gradient(180deg, #1a1a2e 0%, #15152a 100%);
   border-bottom: 1px solid #2d2d44;
   display: flex;
   align-items: center;
   padding: 0 12px;
   cursor: grab;
   flex-shrink: 0;
 }
 .gui-top:active { cursor: grabbing; }

 .brand { display: flex; align-items: center; gap: 10px; flex: 1; }
 .brand-logo {
   width: 28px; height: 28px;
   border-radius: 50%;
   background: linear-gradient(135deg, #4a3aa0, #2d2d44);
   display: flex; align-items: center; justify-content: center;
   font-size: 16px;
   box-shadow: 0 0 10px rgba(120, 90, 230, 0.4);
 }
 .brand-name {
   font-weight: 700; font-size: 14px;
   letter-spacing: 1.5px; color: #d8d2ff;
 }

 .close-btn {
   width: 28px; height: 28px;
   border-radius: 6px;
   background: #2a1320;
   color: #ff6b8b;
   border: 1px solid #5a2a3a;
   display: flex; align-items: center; justify-content: center;
   cursor: pointer;
   font-size: 16px; font-weight: 700; line-height: 1;
   transition: background 0.15s ease, color 0.15s ease;
 }
 .close-btn:hover { background: #ff3b5c; color: #fff; }

 /* Body */
 .gui-body {
   flex: 1; display: flex;
   padding: 12px; gap: 12px;
   min-height: 0;
 }
 .panel {
   background: #12121f;
   border: 1px solid #2d2d44;
   border-radius: 8px;
   padding: 16px;
   display: flex;
   align-items: center; justify-content: center;
   flex-direction: column;
   gap: 8px;
   overflow: hidden;
 }
 .panel-left { width: 180px; flex-shrink: 0; }
 .panel-right { flex: 1; }

 .panel-title {
   font-size: 12px; letter-spacing: 2px;
   color: #6a6a8a; font-weight: 600;
 }
 .panel-text {
   font-size: 20px; font-weight: 700;
   letter-spacing: 3px; color: #b8a8ff;
   text-shadow: 0 0 12px rgba(140, 100, 255, 0.4);
 }
 .ghost-big {
   font-size: 42px; opacity: 0.85;

filter: drop-shadow(0 0 12px rgba(140, 100, 255, 0.45));
 }

 /* Bottom status */
 .gui-bottom {
   height: 26px;
   background: #0a0a12;
   border-top: 1px solid #2d2d44;
   display: flex; align-items: center;
   padding: 0 12px;
   font-size: 10px; color: #5a5a7a;
   letter-spacing: 1.5px;
   flex-shrink: 0;
 }
 .status-dot {
   width: 7px; height: 7px; border-radius: 50%;
   background: #6cf09a;
   box-shadow: 0 0 6px #6cf09a;
   margin-right: 8px;
   animation: pulse 1.6s ease-in-out infinite;
 }
 @keyframes pulse {
   0%, 100% { opacity: 1; }
   50% { opacity: 0.4; }
 }

 /* Mobile */
 @media (max-width: 600px) {
   .gui { width: calc(100vw - 20px); height: auto; max-height: calc(100vh - 20px); }
   .gui-body { flex-direction: column; }
   .panel-left { width: 100%; min-height: 100px; }
   .panel-right { min-height: 180px; }
   .brand-name { font-size: 12px; letter-spacing: 1px; }
 }
</style>
</head>
<body>

<div class="ghost-toggle hidden" id="ghostToggle" title="Open GHOST CLIENT">👻</div>

<div class="gui" id="gui">
 <div class="gui-top" id="guiTop">
   <div class="brand">
     <div class="brand-logo">👻</div>
     <div class="brand-name">GHOST CLIENT</div>
   </div>
   <div class="close-btn" id="closeBtn" title="Close">✕</div>
 </div>

 <div class="gui-body">
   <div class="panel panel-left">
     <div class="ghost-big">👻</div>
     <div class="panel-title">CLIENT</div>
     <div class="panel-text" style="font-size:14px;">GHOST</div>
   </div>
   <div class="panel panel-right">
     <div class="panel-title">STATUS</div>
     <div class="panel-text">READY</div>
   </div>
 </div>

 <div class="gui-bottom">
   <div class="status-dot"></div>
   <span>SYSTEM ONLINE</span>
 </div>
</div>

<script>
(function () {
 const gui = document.getElementById('gui');
 const top = document.getElementById('guiTop');
 const closeBtn = document.getElementById('closeBtn');
 const toggle = document.getElementById('ghostToggle');

 // Restore saved position
 try {
   const saved = JSON.parse(localStorage.getItem('ghostClientPos') || 'null');
   if (saved && typeof saved.left === 'number' && typeof saved.top === 'number') {
     applyPosition(saved.left, saved.top);
   }
 } catch (e) {}

 function applyPosition(left, topPx) {
   gui.style.left = left + 'px';
   gui.style.top = topPx + 'px';
   gui.classList.add('dragged');
 }

 function openGui() {
   toggle.classList.add('hidden');
   requestAnimationFrame(() => gui.classList.remove('hidden'));
 }
 function closeGui() {
   gui.classList.add('hidden');
   setTimeout(() => toggle.classList.remove('hidden'), 180);
 }

 closeBtn.addEventListener('click', (e) => {
   e.stopPropagation();
   closeGui();
 });
 toggle.addEventListener('click', openGui);

 // Drag
 let dragging = false, sx = 0, sy = 0, ox = 0, oy = 0;

 function startDrag(clientX, clientY) {
   const rect = gui.getBoundingClientRect();
   applyPosition(rect.left, rect.top);
   dragging = true;
   sx = clientX; sy = clientY;
   ox = rect.left; oy = rect.top;
 }

 function moveDrag(clientX, clientY) {
   if (!dragging) return;
   let nx = ox + (clientX - sx);
   let ny = oy + (clientY - sy);
   const w = gui.offsetWidth, h = gui.offsetHeight;
   nx = Math.max(0, Math.min(window.innerWidth - w, nx));
   ny = Math.max(0, Math.min(window.innerHeight - h, ny));
   applyPosition(nx, ny);
 }

 function endDrag() {
   if (!dragging) return;
   dragging = false;
   try {
     localStorage.setItem('ghostClientPos', JSON.stringify({
       left: gui.offsetLeft, top: gui.offsetTop
     }));
   } catch (e) {}
 }

 top.addEventListener('mousedown', (e) => {
   if (e.target === closeBtn) return;
   startDrag(e.clientX, e.clientY);
 });
 window.addEventListener('mousemove', (e) => moveDrag(e.clientX, e.clientY));
 window.addEventListener('mouseup', endDrag);

 top.addEventListener('touchstart', (e) => {
   if (e.target === closeBtn) return;
   const t = e.touches[0];
   startDrag(t.clientX, t.clientY);
 }, { passive: true });
 window.addEventListener('touchmove', (e) => {
   const t = e.touches[0];
   if (t) moveDrag(t.clientX, t.clientY);

}, { passive: true });
 window.addEventListener('touchend', endDrag);
})();
</script>
</body>
</html>
