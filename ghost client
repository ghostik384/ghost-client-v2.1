-- Функция безопасного показа GUI (в pcall)
local function showGui(gui)
    if not gui then return false, "gui is nil" end
    local ok, err = pcall(function()
        gui.Enabled = true
    end)
    if not ok then
        return false, tostring(err)
    end
    return true
end

-- Основная логика: подготовка GUI и обработка команды /console
local guiContainer, containerName = getPlayerGuiWithFallback(player)
print(("[DEBUG] GUI контейнер выбран: %s"):format(tostring(containerName)))

-- Создаём GUI в pcall и логируем результат
local createdGui
local ok, createErr = pcall(function()
    local success, err = createGui(guiContainer)
    if not success then
        error(err or "unknown createGui error")
    end
end)

if not ok then
    warn("[ERROR] Причина: " .. tostring(createErr))
else
    print("[DEBUG] GUI успешно создан (или помещён в контейнер).")
    -- Получаем ссылку на созданный GUI (если parent — PlayerGui/CoreGui/StarterGui)
    -- Ищем по имени "GHOST_CLIENT_GUI"
    local foundGui = nil
    -- Попробуем безопасно получить GUI (pcall)
    pcall(function()
        if guiContainer then
            foundGui = guiContainer:FindFirstChild("GHOST_CLIENT_GUI")
        end
    end)
    createdGui = foundGui
end

-- Функция запуска анимации прогресс-бара (1% -> 100% за 7.5 секунд)
local function runProgressAnimation(gui)
    if not gui then return end
    local progressFill = nil
    local percentLabel = nil
    -- Безопасно получить элементы
    pcall(function()
        local main = gui:FindFirstChild("MainFrame")
        if main then
            progressFill = main:FindFirstChild("ProgressBg") and main.ProgressBg:FindFirstChild("ProgressFill")
            percentLabel = main:FindFirstChild("Percent")
        end
    end)
    if not progressFill or not percentLabel then
        warn("[ERROR] Не удалось найти элементы прогресс-бара внутри GUI.")
        return
    end

    -- Анимация: 1% каждые 0.075 с => 100% за 7.5 с
    local percent = 0
    local stepMs = 75 -- миллисекунд
    -- Убедимся, что предыдущие анимации не выполняются (если нужно, можно добавить флаг)
    local running = true
    -- В Roblox нет точного sleep в LocalScript, используем RunService.Heartbeat
    local accumulated = 0
    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if not running then
            if conn then conn:Disconnect() end
            return
        end
        accumulated = accumulated + dt * 1000
        while accumulated >= stepMs and percent < 100 do
            accumulated = accumulated - stepMs
            percent = percent + 1
            -- Обновляем UI в pcall
            pcall(function()
                progressFill.Size = UDim2.new(percent / 100, 0, 1, 0)
                percentLabel.Text = tostring(percent) .. "%"
            end)
        end

        if percent >= 100 then
            running = false
            if conn then conn:Disconnect() end
            -- Плавное скрытие GUI (fade out) — простая реализация: отключаем Enabled
            pcall(function()
                gui.Enabled = false
            end)
            print("[DEBUG] Загрузка завершена, GUI скрыт.")
            -- Здесь можно открыть основную GUI с функциями (если требуется)
            -- В примере мы просто включаем GUI снова как демонстрацию (или можно заменить)
            -- pcall(function() gui.Enabled = true end)
        end
    end)
end

-- Обработчик команды /console
local function onChat(msg)
    if type(msg) ~= "string" then return end
    local lower = msg:lower()
    -- Поддерживаем команды, начинающиеся с "/console" (включая параметры)
    if lower:match("^/console") then
        -- В pcall, чтобы не падать при ошибках
        local ok, err = pcall(function()
            if not createdGui then
                -- Попробуем найти GUI ещё раз (вдруг был создан поздно)
                createdGui = nil
                if guiContainer then
                    createdGui = guiContainer:FindFirstChild("GHOST_CLIENT_GUI")
                end
                if not createdGui then
                    -- Попробуем создать заново
                    local success, createErr = createGui(guiContainer)
                    if not success then
                        error(createErr or "failed to create GUI on /console")
                    end
                    createdGui = guiContainer:FindFirstChild("GHOST_CLIENT_GUI")
                end
            end

            -- Показываем GUI и запускаем прогресс
            local shown, showErr = showGui(createdGui)
            if not shown then
                error(showErr or "failed to enable GUI")
            end

            -- Запускаем анимацию прогресс-бара
            runProgressAnimation(createdGui)
        end)

        if not ok then
            -- Логируем ошибку безопасно
            warn("[ERROR] Причина: " .. tostring(err))
        else
            print("[DEBUG] Обработана команда /console")
        end
    end
end

-- Подключаем обработчик чата безопасно
local chatConnOk, chatConnErr = pcall(function()
    -- Players.LocalPlayer:Chatted exists в LocalScript
    player.Chatted:Connect(onChat)
end)
if not chatConnOk then
    warn("[ERROR] Не удалось подключить обработчик чата: " .. tostring(chatConnErr))
else
    print("[DEBUG] Обработчик чата подключён")
end

