-- Функція анімації закриття (згортання вверх)
local function closeAnimation()
    if isAnimating or not isOpen then return end
    isAnimating = true
    isOpen = false
    
    for i = 0, 1, 0.05 do
        frame.BackgroundTransparency = 0.05 + (i * 0.95)
        frame.Position = UDim2.new(0.5, -190, 0.5 - (i * 0.5), -240 + (i * 240))
        task.wait(0.01)
    end
    
    frame.Visible = false
    isAnimating = false
end

-- Функція анімації відкриття (розгортання вниз)
local function openAnimation()
    if isAnimating or isOpen then return end
    isAnimating = true
    
    frame.Visible = true
    frame.BackgroundTransparency = 1
    frame.Position = UDim2.new(0.5, -190, 0, -240)
    
    for i = 0, 1, 0.05 do
        frame.BackgroundTransparency = 1 - (i * 0.95)
        frame.Position = UDim2.new(0.5, -190, 0 + (i * 0.5), -240 + (i * 240))
        task.wait(0.01)
    end
    
    frame.BackgroundTransparency = 0.05
    frame.Position = UDim2.new(0.5, -190, 0.5, -240)
    isOpen = true
    isAnimating = false
end

