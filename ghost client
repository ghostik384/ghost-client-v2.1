local function updateHitboxDisplay(value)
    local t = (value - 0.5) / 2.5 -- макс 3.0, мін 0.5
    sliderFill.Size = UDim2.new(math.clamp(t, 0, 1), 0, 1, 0)
    knob.Position = UDim2.new(math.clamp(t, 0, 1), -6, -0.1, 0)
    local displayValue = string.format("%.1f", value)
    sizeValueLabel.Text = displayValue .. "x"
    hitboxScale = value
    _G.HitboxScale = value
    print("Hitbox scale set to: " .. value .. "x")
end

