-- ТЕЛЕПОРТ НА СВОЮ ЗОНУ
-- ============================================
local function doInstantSteal(setStatus, zoneNameLbl, zonePosLbl, stealBtn, stealStroke)
    setStatus("🔍 Поиск зоны сбора...", Color3.fromRGB(255,220,50))
    zoneNameLbl.Text = "Зона: поиск..."
    zonePosLbl.Text  = "Координаты: ..."

    task.wait(0.3)

    local pos, name, count = findMyCollectZone()

    if not pos then
        setStatus("✗ Зона не найдена", Color3.fromRGB(255,80,80))
        zoneNameLbl.Text = "Зона: не найдена"
        zonePosLbl.Text  = "Координаты: —"
        tw(stealBtn, {BackgroundColor3=Color3.fromRGB(120,20,50)}, 0.1)
        task.delay(0.3, function()
            tw(stealBtn, {BackgroundColor3=Color3.fromRGB(180,30,80)}, 0.3)
        end)
        return
    end

    zoneNameLbl.Text = "Зона: " .. name
    zonePosLbl.Text  = string.format("X:%.0f  Y:%.0f  Z:%.0f", pos.X, pos.Y, pos.Z)
    setStatus("✓ Найдено " .. count .. " зон | Телепорт...", Color3.fromRGB(80,255,150))

    task.wait(0.15)

    -- Максимальное HP перед телепортом
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChildOfClass("Humanoid")

    if not hrp then
        setStatus("✗ Нет персонажа", Color3.fromRGB(255,80,80))
        return
    end

    pcall(function()
        if hum then
            hum.Health = hum.MaxHealth
            hum.BreakJointsOnDeath = false
        end
    end)

    -- Телепортируем на свою зону сбора
    local safePos = pos + Vector3.new(0, 5, 0)
    hrp.CFrame = CFrame.new(safePos)

    -- Обнуляем скорость чтобы не улететь
    pcall(function() hrp.Velocity        = Vector3.zero end)
    pcall(function() hrp.RotVelocity     = Vector3.zero end)

    -- Восстанавливаем HP после
    task.delay(0.1, function()
        pcall(function()
            if hum and hum.Parent then
                hum.Health = hum.MaxHealth
            end
        end)
    end)

    setStatus("✅ На зоне: " .. name, Color3.fromRGB(80,255,120))

    tw(stealBtn, {BackgroundColor3=Color3.fromRGB(30,180,80)}, 0.15)
    task.delay(1.0, function()
        tw(stealBtn, {BackgroundColor3=Color3.fromRGB(180,30,80)}, 0.3)
        setStatus("Готов к следующему", Color3.fromRGB(120,100,160))
    end)
end

