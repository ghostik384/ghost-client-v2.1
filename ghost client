-- Счётчики здоровья и положения
local lastHealthRestore = 0
local lastPositionCheck = 0
local fallDetection = 0

local function enableAntiReset()
    if antiResetConn then return end
    
    antiResetConn = RunService.Heartbeat:Connect(function()
        pcall(function()
            local char = player.Character
            if not char then return end
            
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            
            if not hrp or not hum then return end
            
            -- ==========================================
            -- УРОВЕНЬ 1: ВОССТАНОВЛЕНИЕ ЗДОРОВЬЯ
            -- ==========================================
            if hum.Health < hum.MaxHealth then
                hum.Health = hum.MaxHealth
                lastHealthRestore = tick()
            end
            
            -- БЛОКИРОВКА СМЕРТИ
            pcall(function() 
                hum.BreakJointsOnDeath = false
                hum.PlatformStand = false
            end)
            
            -- ==========================================
            -- УРОВЕНЬ 2: УДЕРЖАНИЕ ПОЗИЦИИ (100 ФРЕЙМОВ)
            -- ==========================================
            if holdPosition and holdTimeout > 0 then
                -- Прямое восстановление положения
                hrp.CFrame = CFrame.new(holdPosition)
                hrp.Velocity = Vector3.zero
                hrp.RotVelocity = Vector3.zero
                
                -- Дополнительная стабилизация
                hrp.CanCollide = true
                if hrp:FindFirstChild("BodyVelocity") then
                    hrp:FindFirstChild("BodyVelocity"):Destroy()
                end
                
                holdTimeout = holdTimeout - 1
            else
                -- ==========================================
                -- УРОВЕНЬ 3: КОНТРОЛЬ ПАДЕНИЯ
                -- ==========================================
                if hrp.Velocity.Y < -50 then
                    fallDetection = fallDetection + 1
                    if fallDetection > 3 then
                        hrp.Velocity = Vector3.new(hrp.Velocity.X, -10, hrp.Velocity.Z)
                        fallDetection = 0
                    end
                else
                    fallDetection = 0
                end
                
                -- Ограничение вертикальной скорости
                hrp.Velocity = Vector3.new(
                    hrp.Velocity.X,
                    math.max(hrp.Velocity.Y, -15),
                    hrp.Velocity.Z
                )
            end
            
            -- ==========================================
            -- УРОВЕНЬ 4: ЗАЩИТА ОТ РАЗРУШЕНИЯ
            -- ==========================================
            if hum.Health > 0 then
                pcall(function()
                    if char:FindFirstChild("Head") then
                        char.Head.CanCollide = true
                    end
                    for _, limb in ipairs(char:GetChildren()) do
                        if limb:IsA("BasePart") then
                            limb.CanCollide = true
                        end
                    end
                end)
            end
            
        end)
    end)
    
    print("[STEAL] 🛡️ СУПЕР АНТИ-РЕСЕТ v2.0 АКТИВИРОВАН (100+ ФРЕЙМОВ)")
