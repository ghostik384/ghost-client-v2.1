-- Функція анімації згортання
local function collapseGUI()
    if isAnimating or not isOpen then return end
    isAnimating = true
    isOpen = false
    
    for i = 0, 1, 0.05 do
        frame.Size = UDim2.new(0, 380, 0, 380 + (42 - 380) * i)
        contentFrame.BackgroundTransparency = i
        task.wait(0.01)
    end
    
    frame.Size = UDim2.new(0, 380, 0, 42)
    contentFrame.Visible = false
    isAnimating = false
end

-- Функція анімації розгортання
local function expandGUI()
    if isAnimating or isOpen then return end
    isAnimating = true
    
    contentFrame.Visible = true
    for i = 0, 1, 0.05 do
        frame.Size = UDim2.new(0, 380, 0, 42 + (380 - 42) * i)
        contentFrame.BackgroundTransparency = 1 - i
        task.wait(0.01)
    end
    
    frame.Size = UDim2.new(0, 380, 0, 380)
    contentFrame.BackgroundTransparency = 0
    isOpen = true
    isAnimating = false
end

-- === СИСТЕМА ХІТБОКСІВ (РОЗШИРЕННЯ ЧАСТИН ТІЛА) ===
local function setHitboxSize(value)
    for _, v in ipairs(Workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v ~= player.Character then
            for _, part in ipairs(v:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Size = Vector3.new(value, value, value)
                end
            end
        end
    end
end

local function setAllHitboxes()
    setHitboxSize(hitboxMultiplier)
end

-- Відстеження нових об'єктів
Workspace.DescendantAdded:Connect(function(descendant)
    if descendant:IsA("Model") and descendant:FindFirstChild("Humanoid") then
        for _, part in ipairs(descendant:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Size = Vector3.new(hitboxMultiplier, hitboxMultiplier, hitboxMultiplier)
            end
        end
    end
end)

-- === СИСТЕМА ESP (Wallhack + Hitbox View) ===
local function createESP(targetPlayer)
    local espFolder = Instance.new("Folder")
    espFolder.Name = targetPlayer.Name
    
    -- Box ESP (Wallhack)
    local box = Instance.new("BoxHandleAdornment")
    box.Name = "ESPBox"
    box.Size = Vector3.new(2, 3, 1)
    box.Color3 = Color3.fromRGB(255, 0, 0)
    box.Transparency = 0.5
    box.AlwaysOnTop = true
    box.ZIndex = 5
    box.Adornee = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    box.Visible = wallhackEnabled
    box.Parent = espFolder
    
    -- Name ESP
    local nameTag = Instance.new("BillboardGui")
    nameTag.Name = "ESPName"
    nameTag.Size = UDim2.

new(0, 100, 0, 30)
    nameTag.StudsOffset = Vector3.new(0, 3.5, 0)
    nameTag.AlwaysOnTop = true
    nameTag.Adornee = targetPlayer.Character and targetPlayer.Character:FindFirstChild("Head")
    nameTag.Enabled = wallhackEnabled
    nameTag.Parent = espFolder
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = targetPlayer.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Parent = nameTag
    
    -- Hitbox Visual
    local hitbox = Instance.new("BoxHandleAdornment")
    hitbox.Name = "HitboxVisual"
    hitbox.Size = Vector3.new(2, 3, 1)
    hitbox.Color3 = Color3.fromRGB(0, 255, 255)
    hitbox.Transparency = 0.7
    hitbox.AlwaysOnTop = seeHitboxesThroughWalls
    hitbox.ZIndex = 4
    hitbox.Adornee = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    hitbox.Visible = false
    hitbox.Parent = espFolder
    
    espObjects[targetPlayer] = espFolder
    espFolder.Parent = gui
    
    return espFolder
end

-- Оновлення ESP видимості
local function updateESPVisibility()
    for targetPlayer, folder in pairs(espObjects) do
        local box = folder:FindFirstChild("ESPBox")
        local nameTag = folder:FindFirstChild("ESPName")
        
        if box then
            box.Visible = wallhackEnabled
        end
        if nameTag then
            nameTag.Enabled = wallhackEnabled
        end
    end
end

-- Оновлення видимості хітбоксів
local function updateHitboxVisibility()
    for targetPlayer, folder in pairs(espObjects) do
        local hitbox = folder:FindFirstChild("HitboxVisual")
        if hitbox then
            hitbox.Visible = showHitboxes
            hitbox.AlwaysOnTop = seeHitboxesThroughWalls
        end
    end
end

-- Оновлення ESP позицій
local function updateESPPositions()
    for targetPlayer, folder in pairs(espObjects) do
        if targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local box = folder:FindFirstChild("ESPBox")
            local nameTag = folder:FindFirstChild("ESPName")
            local hitbox = folder:FindFirstChild("HitboxVisual")
            
            if box then
                box.Adornee = targetPlayer.Character.HumanoidRootPart
            end
            if nameTag then
                nameTag.Adornee = targetPlayer.Character:FindFirstChild("Head")
            end
            if hitbox then
                hitbox.Adornee = targetPlayer.Character.HumanoidRootPart
            end
        end
    end
end

-- Очищення ESP для гравця
local function removeESP(targetPlayer)
    if espObjects[targetPlayer] then
        espObjects[targetPlayer]:Destroy()
        espObjects[targetPlayer] = nil
    end
end

-- Відстеження гравців
local function onPlayerAdded(newPlayer)
    if newPlayer ~= player then
        createESP(newPlayer)
    end
end

local function onPlayerRemoving(leavingPlayer)
    removeESP(leavingPlayer)
end

-- Додаємо існуючих гравців
for _, existingPlayer in ipairs(Players:GetPlayers()) do
    if existingPlayer ~= player then
        createESP(existingPlayer)
    end
end

Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(onPlayerRemoving)

-- Оновлення ESP кожен кадр
RunService.RenderStepped:Connect(function()
