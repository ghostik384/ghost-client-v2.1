local function updateHitbox(value)
    local norm = (value - 1) / 1.5
    norm = math.clamp(norm, 0, 1)
    sliderFill.Size = UDim2.new(norm, 0, 1, 0)
    hitboxLabel.Text = "Hitbox Size: " .. string.format("%.1f", value) .. "x"
    hitboxMultiplier = value
    updateHitboxSize()
end

-- Логіка перетягування слайдера
local hitboxDrag = false

hitboxSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        hitboxDrag = true
        local mousePos = mouse.X
        local sliderPos = hitboxSlider.AbsolutePosition.X
        local width = hitboxSlider.AbsoluteSize.X
        local t = math.clamp((mousePos - sliderPos) / width, 0, 1)
        local multiplier = 1 + (t * 1.5)
        updateHitbox(multiplier)
    end
end)

hitboxSlider.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        hitboxDrag = false
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        hitboxDrag = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if hitboxDrag and input.UserInputType == Enum.UserInputType.MouseMovement then
        local mousePos = mouse.X
        local sliderPos = hitboxSlider.AbsolutePosition.X
        local width = hitboxSlider.AbsoluteSize.X
        local t = math.clamp((mousePos - sliderPos) / width, 0, 1)
        local multiplier = 1 + (t * 1.5)
        updateHitbox(multiplier)
    end
end)

